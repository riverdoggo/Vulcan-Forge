# Copy to .env (project root) or backend/.env. Do not commit .env.
# Sandbox tasks require Docker Engine running (on Windows: Docker Desktop fully started).

# Required
GROQ_API_KEY=

# Optional — API security (empty = auth disabled for mutating routes)
VULCAN_API_KEY=

# Optional — LLM
# GROQ_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=
# OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=qwen/qwen3-coder:free

# Optional — agent / sandbox
WORKSPACE_ROOT=workspaces
SANDBOX_IMAGE=agent-sandbox
MAX_AGENT_STEPS=30
AGENT_TASK_TIMEOUT=600
LLM_REQUEST_TIMEOUT=60

# Optional — legacy / misc
OLLAMA_URL=http://localhost:11434
LOG_LEVEL=INFO
OLLAMA_TIMEOUT_SEC=120
DOCKER_EXEC_TIMEOUT_SEC=60
REPLAY_MAX_FILES=100
