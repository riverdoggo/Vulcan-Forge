# Copy to .env and set values. Do not commit .env.
# Sandbox tasks require Docker Engine running (on Windows: Docker Desktop fully started).
GROQ_API_KEY=
# Optional overrides (defaults match Groq OpenAI-compatible API)
# GROQ_URL=https://api.groq.com/openai/v1/chat/completions
# GROQ_MODEL=llama-3.3-70b-versatile
WORKSPACE_ROOT=workspaces
SANDBOX_IMAGE=agent-sandbox
OLLAMA_URL=http://localhost:11434
MAX_AGENT_STEPS=30
LOG_LEVEL=INFO
OLLAMA_TIMEOUT_SEC=120
DOCKER_EXEC_TIMEOUT_SEC=60
REPLAY_MAX_FILES=100
